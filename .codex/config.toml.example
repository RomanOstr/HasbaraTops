# Safe example only; this file does not establish a live connection.
[dialogue_lab]
drive_config = "config/drive-files.toml"
connector = "google-drive-plugin"
reads = "automatic"
writes = "explicit-approval"
delete = false
move = false
rename = false
share = false
single_writer = true

# Configure the Google Drive plugin in the Codex environment. Keep OAuth and
# environment-specific connector settings outside the repository.
[mcp.google_drive]
enabled = true
environment_specific_connection = "CONFIGURE_IN_CODEX"
